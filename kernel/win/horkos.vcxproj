<?xml version="1.0" encoding="utf-8"?>
<!--
  kernel/win/horkos.vcxproj
  Role: Canonical WDK/MSBuild project for the Horkos KMDF driver. This is the
        build path that produces a signed catalog for distribution; the
        CMakeLists.txt mirror is for developer convenience only. Open in a
        VS2022 + WDK environment and build Release|x64. See
        docs/windows-build.md and docs/windows-signing.md.
  Target platform: Windows 10/11 x64, KMDF 1.33.
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{B0F1A7C2-3D4E-4F50-9A1B-2C3D4E5F6071}</ProjectGuid>
    <TemplateGuid>{dd38f7fc-d7bd-488b-9242-7d8754cde80d}</TemplateGuid>
    <TargetVersion>Windows10</TargetVersion>
    <MinimumVisualStudioVersion>16.0</MinimumVisualStudioVersion>
    <Configuration>Release</Configuration>
    <Platform Condition="'$(Platform)' == ''">x64</Platform>
    <RootNamespace>horkos</RootNamespace>
    <DriverType>KMDF</DriverType>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Label="Configuration">
    <TargetVersion>Windows10</TargetVersion>
    <UseDebugLibraries Condition="'$(Configuration)'=='Debug'">true</UseDebugLibraries>
    <UseDebugLibraries Condition="'$(Configuration)'=='Release'">false</UseDebugLibraries>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
    <ConfigurationType>Driver</ConfigurationType>
    <DriverType>KMDF</DriverType>
    <DriverTargetPlatform>Universal</DriverTargetPlatform>
    <SpectreMitigation>Spectre</SpectreMitigation>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <PropertyGroup>
    <TargetName>horkos</TargetName>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <TreatWarningAsError>true</TreatWarningAsError>
      <AdditionalIncludeDirectories>$(ProjectDir)include;$(MSBuildThisFileDirectory)..\..\sdk\include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <!-- Driver/module-integrity production defaults: low-FP sensors ON, the
           uncertainty-gated sensors (FLT/CALLBACKS/IMAGEHASH/NONIMAGE/BOOTLOAD)
           stay OFF (not defined) until verified on-box. Mirrors the CMake option
           defaults; documented in docs/windows-build.md. -->
      <!-- Syscall/ETW surface-integrity production defaults (signals 208-216):
           low-FP / exported-only / off-hot-path sensors ON (SSDT 208+216, LSTAR
           210, IDT 214, ETW-TI keepalive half 212); the uncertainty-gated sensors
           (SHADOW_SSDT 209, PROLOGUE 213, ETW_SESSION 215, INFINITYHOOK 211) stay
           OFF until verified on-box. IDT (214) is ON *pending* __sidt/IPI on-box
           confirmation per the plan. Mirrors the CMake option defaults. -->
      <PreprocessorDefinitions>HK_WIN_INTEGRITY_DEBUGSTATE=1;HK_WIN_INTEGRITY_CISTATE=1;HK_WIN_INTEGRITY_SSDT=1;HK_WIN_INTEGRITY_DRVOBJ=1;HK_INTEGRITY_TIMER_MS=30000;HK_WIN_SYSCALL_SSDT=1;HK_WIN_SYSCALL_LSTAR=1;HK_WIN_SYSCALL_IDT=1;HK_WIN_ETW_TI=1;HK_ETW_KEEPALIVE_MIN_DELTA=0;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <!-- PsSetCreateProcessNotifyRoutineEx requires IMAGE_DLLCHARACTERISTICS_
           FORCE_INTEGRITY; SetChecksum alone does NOT set it. -->
      <SetChecksum>true</SetChecksum>
      <AdditionalOptions>/INTEGRITYCHECK %(AdditionalOptions)</AdditionalOptions>
    </Link>
    <DriverSign>
      <FileDigestAlgorithm>sha256</FileDigestAlgorithm>
    </DriverSign>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="src\DriverEntry.c" />
    <ClCompile Include="src\IrpDispatch.c" />
    <ClCompile Include="src\MemScanWorker.c" />
    <ClCompile Include="src\VadWalk.c" />
    <ClCompile Include="src\MemScanVad.c" />
    <ClCompile Include="src\LdrCrosscheck.c" />
    <ClCompile Include="src\HollowDetect.c" />
    <ClCompile Include="src\ExecOrigin.c" />
    <ClCompile Include="src\MemScanPte.c" />
    <ClCompile Include="src\ModuleStomp.c" />
    <ClCompile Include="src\HvSyntheticMsr.c" />
    <ClCompile Include="src\HvEptProbe.c" />
    <ClCompile Include="src\HvSecureKernelLiveness.c" />
    <ClCompile Include="src\HvApicIdtResidue.c" />
    <ClCompile Include="src\proc_genealogy.c" />
    <ClCompile Include="src\launch_timing.c" />
    <ClCompile Include="src\module_reconcile.c" />
    <ClCompile Include="src\Notify.c" />
    <ClCompile Include="src\ThreadProvenance.c" />
    <ClCompile Include="src\RingBuffer.c" />
    <ClCompile Include="src\Callbacks.c" />
    <ClCompile Include="src\CallbackSelfCheck.c" />
    <ClCompile Include="src\RegistryCallback.c" />
    <ClCompile Include="src\Whitelist.c" />
    <!-- win-kernel-driver-integrity (signals 28-36). ModuleMap + HkIntegrityScan
         are the always-compiled shared substrate; each sensor .c compiles to a
         no-op stub unless its HK_WIN_INTEGRITY_* macro is defined. Production
         defaults (low-FP sensors ON) are set via PreprocessorDefinitions in the
         ItemDefinitionGroup above; OFF sensors are simply not defined. To enable
         an uncertainty-gated sensor, add its macro to PreprocessorDefinitions and
         (for signal 28) add fltMgr.lib to AdditionalDependencies. -->
    <ClCompile Include="src\ModuleMap.c" />
    <ClCompile Include="src\HkIntegrityScan.c" />
    <ClCompile Include="src\MinifilterAudit.c" />
    <ClCompile Include="src\ImageHashAudit.c" />
    <ClCompile Include="src\CodeIntegrityProbe.c" />
    <ClCompile Include="src\CallbackResidency.c" />
    <ClCompile Include="src\NonImageCodeScan.c" />
    <ClCompile Include="src\DebugStateProbe.c" />
    <ClCompile Include="src\DriverObjectAudit.c" />
    <ClCompile Include="src\SsdtIntegrity.c" />
    <ClCompile Include="src\BootLoadAudit.c" />
    <!-- win-kernel-syscall-etw-integrity (signals 208-216). KernelImageMap is the
         always-compiled shared cache; SyscallIntegrity/EtwIntegrity sensors
         compile to no-op stubs unless their HK_WIN_SYSCALL_*/HK_WIN_ETW_* macro is
         defined (production defaults set in the ItemDefinitionGroup above). -->
    <ClCompile Include="src\KernelImageMap.c" />
    <ClCompile Include="src\SyscallIntegrity.c" />
    <ClCompile Include="src\EtwIntegrity.c" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="include\horkos_kernel.h" />
    <ClInclude Include="include\selfcheck_fpgate.h" />
    <ClInclude Include="include\module_map_resolve.h" />
    <ClInclude Include="include\ssdt_decode.h" />
  </ItemGroup>
  <ItemGroup>
    <Inf Include="horkos.inf" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
