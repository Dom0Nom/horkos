# String encryption: the string referenced by the annotated function is
# encrypted at build time (its plaintext no longer appears as an initializer),
# made writable, and a decrypt constructor is appended to llvm.global_ctors.
# RUN: %opt -load-pass-plugin=%plugin -passes='hk-strenc,verify' -S %S/fixtures/fixture.ll | %FileCheck %s

# The plaintext literal must be gone from the encrypted global's initializer.
# CHECK-NOT: c"licence-ok\00"

# The string global is now writable (global, not constant) and a decrypt ctor
# is registered.
# CHECK: @.str = private unnamed_addr global
# CHECK: @llvm.global_ctors = {{.*}}@hk_strdec
# CHECK: define internal void @hk_strdec()
# CHECK: xor i8
