# Opaque predicates: the annotated function gains an always-true predicate ANDed
# into its branch; the non-annotated function is untouched.
# RUN: %opt -load-pass-plugin=%plugin -passes=hk-opaque -S %S/fixtures/fixture.ll | %FileCheck %s

# The opaque seed global is created.
# CHECK: @hk_opaque_seed = internal global i32 0

# CHECK-LABEL: define i32 @secret
# CHECK: load volatile i32, ptr @hk_opaque_seed
# CHECK: %hk_op_true = icmp eq
# CHECK: %hk_op_cond = and i1
# CHECK: br i1 %hk_op_cond

# The non-annotated function must carry no opaque-predicate instructions.
# CHECK-LABEL: define i32 @plain
# CHECK-NOT: hk_op
